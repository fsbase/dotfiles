{
  "color_scheme": "Monokai Pro (Filter Spectrum).sublime-color-scheme",
  "theme": "Monokai Pro (Filter Spectrum).sublime-theme",
  "ignored_packages": ["Vintage"],
  "font_face": "Monaco",
  "font_size": 14,
  "font_options": ["no_bold", "no_italic"],
  "translate_tabs_to_spaces": true,
  "ensure_newline_at_eof_on_save": true,
  "highlight_line": true,
  "draw_indent_guides": false,
  "default_line_ending": "system",
  "native_tabs": "system",
  "show_encoding": true,
  "tab_size": 4,
  "margin": 0,
  "spell_check": false,
  "caret_style": "smooth",
  "match_brackets_content": true,
  "scroll_past_end": true,
  "themed_title_bar": true,
  "index_files": false,
  "draw_indent_guides": true,
  "caret_extra_top": 0,
  "caret_extra_bottom": 0,
  "trim_trailing_white_space_on_save": "all",
  "inactive_sheet_dimming": false,
  "highlight_modified_tabs": true,
  // MonoKai Pro
  "monokai_pro_minimal": true,
  "monokai_pro_file_based_icons": true,
}

